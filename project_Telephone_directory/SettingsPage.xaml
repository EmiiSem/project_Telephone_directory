<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:project_Telephone_directory.Controls"
             x:Class="project_Telephone_directory.SettingsPage"
             Title="Настройки">
    <Grid>
        <controls:ShaderBackgroundView x:Name="ShaderBg" />
        <ScrollView Padding="16">
            <VerticalStackLayout Spacing="14">
                <Border BackgroundColor="#55000000" StrokeThickness="0" Padding="8">
                    <WebView x:Name="Gear3d" HeightRequest="180" />
                </Border>
                <Label Text="{Binding StatusMessage}" TextColor="White" />
                <Button Text="Запросить доступ к контактам" Command="{Binding RequestContactsPermissionCommand}" />
                <Button Text="Импорт из телефонной книги" Command="{Binding ImportFromDeviceCommand}" />
                <Button Text="Экспорт JSON" Command="{Binding ExportJsonCommand}" />
                <Button Text="Импорт JSON" Command="{Binding ImportJsonCommand}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
