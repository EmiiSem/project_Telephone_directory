<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:project_Telephone_directory.Controls"
             x:Class="project_Telephone_directory.ContactsListPage"
             Title="Контакты">
    <Grid x:Name="ContactsListHost">
        <controls:ShaderBackgroundView x:Name="ShaderBg" />
        <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="10">
            <Border Grid.Row="0" BackgroundColor="#55000000" StrokeThickness="0" Padding="6">
                <WebView x:Name="SketchfabHeader" HeightRequest="140" />
            </Border>
            <Button Grid.Row="1" Text="Добавить контакт" Command="{Binding AddCommand}" />
            <CollectionView Grid.Row="2" ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,10" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="52"
                                    HeightRequest="52"
                                    VerticalOptions="Center"
                                    StrokeThickness="0"
                                    BackgroundColor="#553388AA">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Grid>
                                    <Image Aspect="AspectFill"
                                           IsVisible="{Binding HasAvatar}"
                                           Source="{Binding AvatarLocalPath}" />
                                    <Label FontAttributes="Bold"
                                           FontSize="16"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAvatar, Converter={StaticResource InvertBool}}"
                                           Text="{Binding Initials}"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontSize="18" TextColor="White" />
                                <Label Text="{Binding Phone}" FontSize="14" TextColor="#DDFFFFFF" />
                                <HorizontalStackLayout Margin="0,6,0,0" Spacing="8">
                                    <Button Padding="10,6"
                                            Command="{Binding Source={x:Reference ContactsListHost}, Path=BindingContext.OpenDetailCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12"
                                            Text="Открыть" />
                                    <Button Padding="10,6"
                                            Command="{Binding Source={x:Reference ContactsListHost}, Path=BindingContext.EditContactCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12"
                                            Text="Изменить" />
                                    <Button Padding="10,6"
                                            BackgroundColor="#883333"
                                            Command="{Binding Source={x:Reference ContactsListHost}, Path=BindingContext.DeleteContactCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12"
                                            Text="Удалить" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
