<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:project_Telephone_directory.ViewModels"
             x:Class="project_Telephone_directory.ContactDetailPage"
             x:DataType="vm:ContactDetailViewModel"
             Title="Контакт"
             BackgroundColor="#14161E">
    <Grid>
        <BoxView Color="#14161E" />
        <ScrollView Padding="16">
            <VerticalStackLayout Spacing="14">
                <Border BackgroundColor="#55000000"
                        StrokeThickness="0"
                        Padding="6"
                        HorizontalOptions="Fill">
                    <WebView x:Name="SketchHeader" HeightRequest="160" />
                </Border>

                <Button Command="{Binding AddNewContactCommand}"
                        Text="+ Новый контакт"
                        BackgroundColor="#44FFFFFF"
                        TextColor="White" />

                <Border WidthRequest="120"
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        BackgroundColor="#55336699">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="60" />
                    </Border.StrokeShape>
                    <Grid>
                        <Image Aspect="AspectFill"
                               IsVisible="{Binding Contact.HasAvatar, FallbackValue=False, TargetNullValue=False}"
                               Source="{Binding Contact.AvatarLocalPath}" />
                        <Label FontAttributes="Bold"
                               FontSize="36"
                               HorizontalOptions="Center"
                               IsVisible="{Binding Contact.HasAvatar, Converter={StaticResource InvertBool}, FallbackValue=True, TargetNullValue=True}"
                               Text="{Binding Contact.Initials}"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Label Text="{Binding Contact.Name}"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="White" />

                <VerticalStackLayout Spacing="6">
                    <Label Text="Телефон"
                           FontSize="13"
                           TextColor="#99FFFFFF" />
                    <Label Text="{Binding Contact.Phone}"
                           FontSize="18"
                           TextColor="White" />
                    <Label Text="Email"
                           FontSize="13"
                           TextColor="#99FFFFFF"
                           Margin="0,10,0,0" />
                    <Label Text="{Binding Contact.Email}"
                           FontSize="18"
                           TextColor="White" />
                </VerticalStackLayout>

                <Label Text="Заметки" FontSize="13" TextColor="#99FFFFFF" />
                <Label Text="{Binding Contact.Notes, TargetNullValue=''}"
                       TextColor="#EEFFFFFF" />

                <Button Text="Редактировать" Command="{Binding EditCommand}" />
                <Button Text="Удалить"
                        Command="{Binding DeleteCommand}"
                        BackgroundColor="#8B3333" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
