<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project_Telephone_directory.ContactEditPage"
             Title="Контакт"
             BackgroundColor="#14161E">
    <Grid>
        <BoxView x:Name="ValidationBg" Color="#14161E" />
        <ScrollView Padding="16">
            <VerticalStackLayout Spacing="12">
                <Border WidthRequest="128"
                        HeightRequest="128"
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        BackgroundColor="#55336699">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="64" />
                    </Border.StrokeShape>
                    <Grid>
                        <Image x:Name="AvatarImage" Aspect="AspectFill" />
                        <Label x:Name="AvatarPlaceholder"
                               FontSize="13"
                               HorizontalOptions="Center"
                               Text="Нет фото"
                               TextColor="#AAFFFFFF"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                    <Button x:Name="BtnPickAvatar" Text="Выбрать фото" />
                    <Button x:Name="BtnClearAvatar" Text="Убрать фото" />
                </HorizontalStackLayout>
                <Label Text="Имя *" TextColor="White" />
                <Entry x:Name="EntryName" TextColor="White" PlaceholderColor="#AAFFFFFF" />
                <Label Text="Телефон" TextColor="White" />
                <Entry x:Name="EntryPhone" Keyboard="Telephone" TextColor="White" PlaceholderColor="#AAFFFFFF" />
                <Label Text="Email" TextColor="White" />
                <Entry x:Name="EntryEmail" Keyboard="Email" TextColor="White" PlaceholderColor="#AAFFFFFF" />
                <Label Text="Заметки" TextColor="White" />
                <Editor x:Name="EditorNotes"
                        AutoSize="Disabled"
                        HeightRequest="120"
                        TextColor="White"
                        PlaceholderColor="#AAFFFFFF" />
                <Button x:Name="BtnSave" Text="Сохранить" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
